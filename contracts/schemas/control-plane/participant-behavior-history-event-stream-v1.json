{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "items": {
    "$defs": {
      "ParticipantInteractionClass": {
        "description": "SEM-209 interaction classes for multi-participant behavior.",
        "enum": [
          "coordination",
          "contention",
          "interference",
          "shared_state_change"
        ],
        "title": "ParticipantInteractionClass",
        "type": "string"
      }
    },
    "additionalProperties": false,
    "properties": {
      "action_contract_address": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Action Contract Address"
      },
      "action_instance_id": {
        "title": "Action Instance Id",
        "type": "string"
      },
      "actor_provenance": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Actor Provenance"
      },
      "details": {
        "additionalProperties": true,
        "title": "Details",
        "type": "object"
      },
      "episode_id": {
        "title": "Episode Id",
        "type": "string"
      },
      "event_type": {
        "title": "Event Type",
        "type": "string"
      },
      "interaction_class": {
        "anyOf": [
          {
            "$ref": "#/$defs/ParticipantInteractionClass"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "interaction_ref": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Interaction Ref"
      },
      "joint_action_set_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Joint Action Set Id"
      },
      "observation_boundary_address": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Observation Boundary Address"
      },
      "observation_status": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Observation Status"
      },
      "participant_address": {
        "title": "Participant Address",
        "type": "string"
      },
      "post_state_digest": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Post State Digest"
      },
      "realized_order": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Realized Order"
      },
      "shared_state_refs": {
        "items": {
          "minLength": 1,
          "type": "string"
        },
        "title": "Shared State Refs",
        "type": "array"
      },
      "state_transition_kind": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "State Transition Kind"
      },
      "timestamp": {
        "title": "Timestamp",
        "type": "string"
      }
    },
    "required": [
      "event_type",
      "timestamp",
      "participant_address",
      "episode_id",
      "action_instance_id"
    ],
    "title": "ParticipantBehaviorHistoryEventModel",
    "type": "object"
  },
  "title": "ParticipantBehaviorHistoryEventStream",
  "type": "array"
}
