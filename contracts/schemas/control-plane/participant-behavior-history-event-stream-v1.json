      "description": "Semantic layers that may feed a SEM-215 interpretation rule.",
      "enum": [
        "participant_action_outcome",
        "participant_episode_status",
        "objective_result",
        "workflow_result",
        "evaluation_result",
        "evidence_claim",
        "reward_signal",
        "benchmark_milestone",
        "subtask",
        "gold_step",
        "human_assistance",
        "scaffold_variant",
        "cost_resource_telemetry",
        "privacy_redaction_result"
      ],
      "title": "OutcomeInterpretationSourceLayer",
      "type": "string"
    },
    "OutcomeInterpretationTargetLayer": {
      "description": "Semantic layers a SEM-215 interpretation rule may explicitly produce.",
      "enum": [
        "scenario_meaning",
        "objective_result",
