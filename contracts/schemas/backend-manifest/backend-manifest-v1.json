{
  "$defs": {
    "EvaluatorCapabilitiesModel": {
      "additionalProperties": false,
      "allOf": [
        {
          "not": {
            "allOf": [
              {
                "properties": {
                  "supports_scoring": {
                    "const": false
                  }
                },
                "required": [
                  "supports_scoring"
                ]
              },
              {
                "properties": {
                  "supports_objectives": {
                    "const": false
                  }
                },
                "required": [
                  "supports_objectives"
                ]
              }
            ]
          }
        }
      ],
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "supported_sections": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Supported Sections",
          "type": "array"
        },
        "supports_objectives": {
          "default": true,
          "title": "Supports Objectives",
          "type": "boolean"
        },
        "supports_scoring": {
          "default": true,
          "title": "Supports Scoring",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "supported_sections"
      ],
      "title": "EvaluatorCapabilitiesModel",
      "type": "object"
    },
    "OrchestratorCapabilitiesModel": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "supports_workflows": {
                "const": true
              }
            },
            "required": [
              "supports_workflows"
            ]
          },
          "then": {
            "properties": {
              "supported_sections": {
                "contains": {
                  "const": "workflows"
                }
              },
              "supported_workflow_features": {
                "minItems": 1
              }
            },
            "required": [
              "supported_workflow_features",
              "supported_sections"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "supports_workflows": {
                "const": false
              }
            },
            "required": [
              "supports_workflows"
            ]
          },
          "then": {
            "properties": {
              "supported_sections": {
                "not": {
                  "contains": {
                    "const": "workflows"
                  }
                }
              },
              "supported_workflow_features": {
                "maxItems": 0
              },
              "supported_workflow_state_predicates": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "supported_sections": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Supported Sections",
          "type": "array"
        },
        "supported_workflow_features": {
          "items": {
            "$ref": "#/$defs/WorkflowFeature"
          },
          "title": "Supported Workflow Features",
          "type": "array"
        },
        "supported_workflow_state_predicates": {
          "items": {
            "$ref": "#/$defs/WorkflowStatePredicateFeature"
          },
          "title": "Supported Workflow State Predicates",
          "type": "array"
        },
        "supports_condition_refs": {
          "default": true,
          "title": "Supports Condition Refs",
          "type": "boolean"
        },
        "supports_inject_bindings": {
          "default": true,
          "title": "Supports Inject Bindings",
          "type": "boolean"
        },
        "supports_workflows": {
          "default": false,
          "title": "Supports Workflows",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "supported_sections"
      ],
      "title": "OrchestratorCapabilitiesModel",
      "type": "object"
    },
    "ProvisionerCapabilitiesModel": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "supports_accounts": {
                "const": true
              }
            },
            "required": [
              "supports_accounts"
            ]
          },
          "then": {
            "properties": {
              "supported_account_features": {
                "minItems": 1
              }
            },
            "required": [
              "supported_account_features"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "supports_accounts": {
                "const": false
              }
            },
            "required": [
              "supports_accounts"
            ]
          },
          "then": {
            "properties": {
              "supported_account_features": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "max_total_nodes": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Total Nodes"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "supported_account_features": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Supported Account Features",
          "type": "array"
        },
        "supported_content_types": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Supported Content Types",
          "type": "array"
        },
        "supported_node_types": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Supported Node Types",
          "type": "array"
        },
        "supported_os_families": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Supported Os Families",
          "type": "array"
        },
        "supports_accounts": {
          "default": false,
          "title": "Supports Accounts",
          "type": "boolean"
        },
        "supports_acls": {
          "default": false,
          "title": "Supports Acls",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "supported_node_types",
        "supported_os_families"
      ],
      "title": "ProvisionerCapabilitiesModel",
      "type": "object"
    },
    "WorkflowFeature": {
      "description": "Portable workflow control features that an orchestrator may support.",
      "enum": [
        "decision",
        "switch",
        "retry",
        "call",
        "parallel-barrier",
        "failure-transitions",
        "cancellation",
        "timeouts",
        "compensation"
      ],
      "title": "WorkflowFeature",
      "type": "string"
    },
    "WorkflowStatePredicateFeature": {
      "description": "Portable workflow state-predicate features that an orchestrator may support.",
      "enum": [
        "outcome-matching",
        "attempt-counts"
      ],
      "title": "WorkflowStatePredicateFeature",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "evaluator": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvaluatorCapabilitiesModel"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "orchestrator": {
      "anyOf": [
        {
          "$ref": "#/$defs/OrchestratorCapabilitiesModel"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "provisioner": {
      "$ref": "#/$defs/ProvisionerCapabilitiesModel"
    },
    "schema_version": {
      "const": "backend-manifest/v1",
      "default": "backend-manifest/v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "name",
    "provisioner"
  ],
  "title": "BackendManifestModel",
  "type": "object"
}
