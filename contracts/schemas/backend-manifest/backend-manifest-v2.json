{
  "$defs": {
    "ApparatusCompatibilityModel": {
      "additionalProperties": false,
      "properties": {
        "backends": {
          "items": {
            "type": "string"
          },
          "title": "Backends",
          "type": "array"
        },
        "participant_implementations": {
          "items": {
            "type": "string"
          },
          "title": "Participant Implementations",
          "type": "array"
        },
        "processors": {
          "items": {
            "type": "string"
          },
          "title": "Processors",
          "type": "array"
        }
      },
      "title": "ApparatusCompatibilityModel",
      "type": "object"
    },
    "ApparatusIdentityModel": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "ApparatusIdentityModel",
      "type": "object"
    },
    "BackendCapabilitiesV2Model": {
      "additionalProperties": false,
      "properties": {
        "evaluator": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvaluatorCapabilitiesModel"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "orchestrator": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrchestratorCapabilitiesModel"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "provisioner": {
          "$ref": "#/$defs/ProvisionerCapabilitiesModel"
        }
      },
      "required": [
        "provisioner"
      ],
      "title": "BackendCapabilitiesV2Model",
      "type": "object"
    },
    "EvaluatorCapabilitiesModel": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "supported_sections": {
          "items": {
            "type": "string"
          },
          "title": "Supported Sections",
          "type": "array"
        },
        "supports_objectives": {
          "default": true,
          "title": "Supports Objectives",
          "type": "boolean"
        },
        "supports_scoring": {
          "default": true,
          "title": "Supports Scoring",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "EvaluatorCapabilitiesModel",
      "type": "object"
    },
    "OrchestratorCapabilitiesModel": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "supported_sections": {
          "items": {
            "type": "string"
          },
          "title": "Supported Sections",
          "type": "array"
        },
        "supported_workflow_features": {
          "items": {
            "$ref": "#/$defs/WorkflowFeature"
          },
          "title": "Supported Workflow Features",
          "type": "array"
        },
        "supported_workflow_state_predicates": {
          "items": {
            "$ref": "#/$defs/WorkflowStatePredicateFeature"
          },
          "title": "Supported Workflow State Predicates",
          "type": "array"
        },
        "supports_condition_refs": {
          "default": true,
          "title": "Supports Condition Refs",
          "type": "boolean"
        },
        "supports_inject_bindings": {
          "default": true,
          "title": "Supports Inject Bindings",
          "type": "boolean"
        },
        "supports_workflows": {
          "default": false,
          "title": "Supports Workflows",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "OrchestratorCapabilitiesModel",
      "type": "object"
    },
    "ProvisionerCapabilitiesModel": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "max_total_nodes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Total Nodes"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "supported_account_features": {
          "items": {
            "type": "string"
          },
          "title": "Supported Account Features",
          "type": "array"
        },
        "supported_content_types": {
          "items": {
            "type": "string"
          },
          "title": "Supported Content Types",
          "type": "array"
        },
        "supported_node_types": {
          "items": {
            "type": "string"
          },
          "title": "Supported Node Types",
          "type": "array"
        },
        "supported_os_families": {
          "items": {
            "type": "string"
          },
          "title": "Supported Os Families",
          "type": "array"
        },
        "supports_accounts": {
          "default": false,
          "title": "Supports Accounts",
          "type": "boolean"
        },
        "supports_acls": {
          "default": false,
          "title": "Supports Acls",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "ProvisionerCapabilitiesModel",
      "type": "object"
    },
    "RealizationSupportDeclarationModel": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "object"
        },
        "disclosure_kinds": {
          "items": {
            "type": "string"
          },
          "title": "Disclosure Kinds",
          "type": "array"
        },
        "domain": {
          "minLength": 1,
          "title": "Domain",
          "type": "string"
        },
        "support_mode": {
          "$ref": "#/$defs/RealizationSupportMode"
        },
        "supported_constraint_kinds": {
          "items": {
            "type": "string"
          },
          "title": "Supported Constraint Kinds",
          "type": "array"
        },
        "supported_exact_requirement_kinds": {
          "items": {
            "type": "string"
          },
          "title": "Supported Exact Requirement Kinds",
          "type": "array"
        }
      },
      "required": [
        "domain",
        "support_mode"
      ],
      "title": "RealizationSupportDeclarationModel",
      "type": "object"
    },
    "RealizationSupportMode": {
      "description": "How an apparatus can supply realizations for underspecified inputs.",
      "enum": [
        "exact-only",
        "constrained",
        "open-realization"
      ],
      "title": "RealizationSupportMode",
      "type": "string"
    },
    "WorkflowFeature": {
      "description": "Portable workflow control features that an orchestrator may support.",
      "enum": [
        "decision",
        "switch",
        "retry",
        "call",
        "parallel-barrier",
        "failure-transitions",
        "cancellation",
        "timeouts",
        "compensation"
      ],
      "title": "WorkflowFeature",
      "type": "string"
    },
    "WorkflowStatePredicateFeature": {
      "description": "Portable workflow state-predicate features that an orchestrator may support.",
      "enum": [
        "outcome-matching",
        "attempt-counts"
      ],
      "title": "WorkflowStatePredicateFeature",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "$ref": "#/$defs/BackendCapabilitiesV2Model"
    },
    "compatibility": {
      "$ref": "#/$defs/ApparatusCompatibilityModel"
    },
    "constraints": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "object"
    },
    "identity": {
      "$ref": "#/$defs/ApparatusIdentityModel"
    },
    "realization_support": {
      "items": {
        "$ref": "#/$defs/RealizationSupportDeclarationModel"
      },
      "title": "Realization Support",
      "type": "array"
    },
    "schema_version": {
      "const": "backend-manifest/v2",
      "default": "backend-manifest/v2",
      "title": "Schema Version",
      "type": "string"
    },
    "supported_contract_versions": {
      "items": {
        "type": "string"
      },
      "title": "Supported Contract Versions",
      "type": "array"
    }
  },
  "required": [
    "identity",
    "capabilities"
  ],
  "title": "BackendManifestV2Model",
  "type": "object"
}
