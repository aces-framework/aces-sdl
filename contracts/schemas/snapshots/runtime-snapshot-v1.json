    "participant_episode_results": {
      "additionalProperties": {
        "$ref": "#/$defs/ParticipantEpisodeStateModel"
      },
      "title": "Participant Episode Results",
      "type": "object"
    },
    "schema_version": {
      "const": "runtime-snapshot/v1",
      "default": "runtime-snapshot/v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
