{
  "$defs": {
    "ConceptFamilyDefinitionModel": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "provenance": {
                "const": "adopted"
              }
            },
            "required": [
              "provenance"
            ]
          },
          "then": {
            "properties": {
              "authority": {
                "minLength": 1,
                "type": "string"
              },
              "authority_reference": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "authority",
              "authority_reference"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "provenance": {
                "const": "adapted"
              }
            },
            "required": [
              "provenance"
            ]
          },
          "then": {
            "properties": {
              "authority": {
                "minLength": 1,
                "type": "string"
              },
              "authority_reference": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "authority",
              "authority_reference"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "provenance": {
                "const": "native"
              }
            },
            "required": [
              "provenance"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "authority"
                  ]
                },
                {
                  "required": [
                    "authority_reference"
                  ]
                }
              ]
            },
            "properties": {
              "extension_scope": {
                "minLength": 1,
                "type": "string"
              },
              "non_ambiguity_constraints": {
                "minItems": 1,
                "type": "array"
              },
              "relation_rules": {
                "minItems": 1,
                "type": "array"
              }
            },
            "required": [
              "extension_scope",
              "relation_rules",
              "non_ambiguity_constraints"
            ]
          }
        }
      ],
      "properties": {
        "authority": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authority"
        },
        "authority_reference": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Authority Reference"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "extension_scope": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extension Scope"
        },
        "non_ambiguity_constraints": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Non Ambiguity Constraints",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/ConceptProvenanceCategory"
        },
        "relation_rules": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Relation Rules",
          "type": "array"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "provenance"
      ],
      "title": "ConceptFamilyDefinitionModel",
      "type": "object"
    },
    "ConceptProvenanceCategory": {
      "description": "How a concept family relates to its authority source.",
      "enum": [
        "adopted",
        "adapted",
        "native"
      ],
      "title": "ConceptProvenanceCategory",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "families": {
      "additionalProperties": {
        "$ref": "#/$defs/ConceptFamilyDefinitionModel"
      },
      "minProperties": 1,
      "propertyNames": {
        "minLength": 1
      },
      "title": "Families",
      "type": "object"
    },
    "schema_version": {
      "const": "concept-families/v1",
      "default": "concept-families/v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "families"
  ],
  "title": "ConceptFamilyCatalogModel",
  "type": "object"
}
