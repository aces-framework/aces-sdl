{
  "$defs": {
    "ProcessorFeature": {
      "description": "Processing features that a processor may support.",
      "enum": [
        "compilation",
        "planning",
        "orchestration-coordination",
        "evaluation-coordination",
        "workflow-semantics",
        "objective-window-consistency",
        "dependency-ordering",
        "runtime-control-plane"
      ],
      "title": "ProcessorFeature",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "compatible_backends": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Compatible Backends",
      "type": "array"
    },
    "constraints": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "object"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "schema_version": {
      "const": "processor-manifest/v1",
      "default": "processor-manifest/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "supported_contract_versions": {
      "items": {
        "enum": [
          "processor-manifest-v1",
          "processor-manifest-v2",
          "provisioning-plan-v1",
          "orchestration-plan-v1",
          "evaluation-plan-v1",
          "workflow-cancellation-request-v1",
          "operation-receipt-v1",
          "operation-status-v1",
          "runtime-snapshot-v1",
          "workflow-result-envelope-v1",
          "workflow-history-event-stream-v1",
          "evaluation-result-envelope-v1",
          "evaluation-history-event-stream-v1"
        ],
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Supported Contract Versions",
      "type": "array"
    },
    "supported_features": {
      "items": {
        "$ref": "#/$defs/ProcessorFeature"
      },
      "minItems": 1,
      "title": "Supported Features",
      "type": "array"
    },
    "supported_sdl_versions": {
      "items": {
        "enum": [
          "sdl-authoring-input-v1"
        ],
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Supported Sdl Versions",
      "type": "array"
    },
    "version": {
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "name",
    "version",
    "supported_sdl_versions",
    "supported_contract_versions",
    "supported_features",
    "compatible_backends"
  ],
  "title": "ProcessorManifestModel",
  "type": "object"
}
