        },
        "macos": {
          "title": "macOS",
          "description": "macOS operating system family."
        },
        "freebsd": {
          "title": "FreeBSD",
          "description": "FreeBSD operating system family."
        },
        "other": {
          "title": "Other",
          "description": "Portable catch-all when no standard family applies."
        }
      }
    },
